<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.txd.guizhoujob.user.mapper.SysUserMapper">

    <resultMap id="SysUserResultMap" type="org.txd.guizhoujob.user.entity.SysUser">
        <id property="id" column="id"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="nickname" column="nickname"/>
        <result property="localCity" column="local_city"/>
        <result property="educationText" column="education_text"/>
        <result property="expectedPosition" column="expected_position"/>
        <result property="expectedSalaryMin" column="expected_salary_min"/>
        <result property="expectedSalaryMax" column="expected_salary_max"/>
        <result property="skillInputText" column="skill_input_text"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, email, password_hash, nickname, local_city, education_text,
        expected_position, expected_salary_min, expected_salary_max,
        skill_input_text, status, create_time, update_time
    </sql>

    <select id="selectByEmail" resultMap="SysUserResultMap">
        select <include refid="Base_Column_List"/>
        from sys_user
        where email = #{email}
        limit 1
    </select>

    <select id="selectById" resultMap="SysUserResultMap">
        select <include refid="Base_Column_List"/>
        from sys_user
        where id = #{id}
        limit 1
    </select>

    <insert id="insert" parameterType="org.txd.guizhoujob.user.entity.SysUser" useGeneratedKeys="true" keyProperty="id">
        insert into sys_user (
        email, password_hash, nickname, status
        ) values (
        #{email}, #{passwordHash}, #{nickname}, #{status}
        )
    </insert>

    <update id="updateProfile" parameterType="org.txd.guizhoujob.user.entity.SysUser">
        update sys_user
        <set>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="localCity != null">local_city = #{localCity},</if>
            <if test="educationText != null">education_text = #{educationText},</if>
            <if test="expectedPosition != null">expected_position = #{expectedPosition},</if>
            <if test="expectedSalaryMin != null">expected_salary_min = #{expectedSalaryMin},</if>
            <if test="expectedSalaryMax != null">expected_salary_max = #{expectedSalaryMax},</if>
            <if test="skillInputText != null">skill_input_text = #{skillInputText},</if>
            update_time = now()
        </set>
        where id = #{id}
    </update>
</mapper>
